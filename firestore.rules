rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own document
    match /users/{email} {
      allow read: if true; // Allow reading balance etc for login check
      allow write: if true; // Temporarily allow for registration until logic is fully shifted
    }
    
    // Orders can be read by admins or the creator
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // Deposits can be read by admins or the creator
    match /deposits/{depositId} {
      allow read, write: if true;
    }
  }
}
